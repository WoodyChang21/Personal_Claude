# Copy to .env and fill in real values. Never commit .env.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gmail sender address
GMAIL_SENDER=you@gmail.com

# Gmail API OAuth2 (preferred — works from remote agents, no DMARC issues)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Gmail SMTP app password (local fallback only — blocked in remote CCR agents)
GMAIL_APP_PASSWORD=

# SendGrid (not usable with @gmail.com senders due to Gmail DMARC policy)
SENDGRID_API_KEY=
